# Local PostgreSQL (required)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/app_db

# Optional privacy salt. Keep this secret and stable in production.
DEVICE_ID_SALT=replace-with-a-long-random-secret

# Optional Cloudflare/edge WebSocket endpoint. Local mode uses PostgreSQL polling.
NEXT_PUBLIC_WS_URL=

# Optional future auth / anti-spam integrations
JWT_SECRET=
TURNSTILE_SECRET_KEY=
